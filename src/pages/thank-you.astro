---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thank You | Power Grab TX">
  <div class="thank-you-section">
    <img
      src="/powergrabtx.png"
      alt="Power Grab TX"
      class="thank-you-logo"
    />
    <h1>Thank You!</h1>
    <p>
      Your message has been received. We'll get back to you as soon as
      possible.
    </p>
    <a href="/" class="btn">Back to Home</a>
  </div>
</Layout>
<style>
  /* ══════════════════════════════════════════════════════════════
         MOVE TO → thank-you page (e.g. src/pages/thank-you.astro)
         ══════════════════════════════════════════════════════════════ */

      .thank-you-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 4rem 1.5rem;
        max-width: 600px;
        margin: 0 auto;
      }

      .thank-you-logo {
        width: 180px;
        height: auto;
        margin-bottom: 1.5rem;
      }

      .thank-you-section h1 {
        font-size: 2rem;
        margin-bottom: 0.75rem;
      }

      .thank-you-section p {
        color: #555;
        margin-bottom: 2rem;
        line-height: 1.5;
      }

</style>