---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Stay Informed — Power Grab TX">
  <div class="page-header">
    <h2>Stay Informed</h2>
    <p>
      Power Grab TX keeps you updated with important news, project developments,
      and new content as it's published. Subscribe to the newsletter below, or
      reach out directly using the contact form.
    </p>
  </div>

  <div class="form-section">
  <form action="https://forms-worker.marc-897.workers.dev" method="POST">
    <input type="text" name="company" style="display:none" tabindex="-1" autocomplete="off" />
    <div class="form-row">
      <div class="field">
        <label>First Name <span class="required">*</span></label>
        <input
          type="text"
          name="first_name"
          placeholder="First Name"
          required
        />
      </div>
      <div class="field">
        <label>Last Name</label>
        <input type="text" name="last_name" placeholder="Last Name" />
      </div>
    </div>
    <div class="field">
      <label>Email <span class="required">*</span></label>
      <input type="email" name="email" placeholder="Email Address" required />
    </div>
    <div class="field">
      <label>Subject <span class="required">*</span></label>
      <input type="text" name="subject" placeholder="Subject" required />
    </div>
    <div class="field">
      <label>Your Message <span class="required">*</span></label>
      <textarea name="message" placeholder="Your Message" required></textarea>
    </div>

    <div class="cf-turnstile" data-sitekey="0x4AAAAAADwCpEAeGLLtdeFU"></div>

    <button type="submit" class="btn">Submit Form</button>
  </form>
</div>

  <div class="newsletter">
    <div class="newsletter-inner">
      <h3>Subscribe to the Power Grab TX Morning Briefing</h3>
      <p>Get updates, analysis, and alerts delivered straight to your inbox.</p>
      <form action="https://forms-worker.marc-897.workers.dev/newsletter" method="POST">
  <input type="text" name="company" style="display:none" tabindex="-1" autocomplete="off" />
  <!-- existing newsletter fields -->
        <div class="form-row">
          <div class="field">
            <label>First Name <span class="required">*</span></label>
            <input
              type="text"
              name="first_name"
              placeholder="First Name"
              required
            />
          </div>
          <div class="field">
            <label>Last Name</label>
            <input type="text" name="last_name" placeholder="Last Name" />
          </div>
        </div>
        <div class="field">
          <label>Email <span class="required">*</span></label>
          <input
            type="email"
            name="email"
            placeholder="Email Address"
            required
          />
        </div>

        <div class="cf-turnstile" data-sitekey="0x4AAAAAADwCpEAeGLLtdeFU"></div>
        
        <button type="submit" class="btn">Submit Form</button></br>
      </form>
    </div>
  </div>
</Layout>
<style>
   /* ══════════════════════════════════════════════════════════════
         MOVE TO → src/pages/stay-informed.astro (contact / signup form)
         ══════════════════════════════════════════════════════════════ */

      .form-section {
        max-width: 560px;
        margin: 0 auto;
        padding: 0 2rem 3rem;
      }
      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
      }
      @media (max-width: 600px) {
        .form-row {
          grid-template-columns: 1fr;
        }
      }
      .field {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        margin-bottom: 1rem;
      }
      label {
        font-size: 0.95rem;
        font-weight: 600;
      }
      .required {
        color: red;
      }
      input,
      textarea {
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 0.6rem 0.8rem;
        font-size: 1rem;
        font-family: "Lato", sans-serif;
        width: 100%;
      }
      textarea {
        height: 120px;
        resize: vertical;
      }
      input:focus,
      textarea:focus {
        outline: 2px solid #1a4a8a;
        border-color: #1a4a8a;
      }
      .newsletter {
        background: #f4f4f4;
        border-radius: 10px;
        max-width: 1200px;
        margin: 0 auto;
        margin-top: 2rem;
      }
      .newsletter-inner {
        max-width: 560px;
        padding: 20px;
        margin: 0 auto;
      }
      .newsletter h3 {
        font-size: 1.5rem;
        font-weight: 700;
        padding-top: 2rem;
        margin-bottom: 0.6rem;
      }
      .newsletter p {
        font-size: 1rem;
        color: #444;
        margin-bottom: 1.2rem;
      }
</style>
