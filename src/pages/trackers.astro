---

<Layout title="AI Data Center Tracker | Power Grab TX">
  <section class="page-header">
    <h2>Texas AI Data Center Tracker</h2>
    <p>
      A running, dated record of what's happening as the AI data center boom
      reshapes Texas — grid strain, water use, land deals, and who's building
      where. Every entry links back to its original source. Updated as new
      stories break.
    </p>
  </section>

  <section class="tracker-section">
    <div class="tracker-inner">
      {
        entries.map((e) => (
          <div class="tracker-entry">
            <p class="tracker-date">{e.date}</p>
            <h3>
              <a href={e.url} target="_blank" rel="noopener">
                {e.headline}
              </a>
            </h3>
            <p class="tracker-source">{e.source}</p>
            <p class="tracker-take">{e.take}</p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
<style>
  /* ══════════════════════════════════════════════════════════════
         MOVE TO → src/pages/trackers.astro
         ══════════════════════════════════════════════════════════════ */

  .tracker-entry {
    padding: 1.5rem 0;
    border-bottom: 1px solid #e8c9b0;
  }

  .tracker-entry:first-child {
    padding-top: 0;
  }

  .tracker-section {
    padding: 3rem 2rem;
  }
  .tracker-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .tracker-date {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #b03a1a;
    margin-bottom: 0.3rem;
  }

  .tracker-entry h3 {
    font-size: 1.15rem;
    margin-bottom: 0.3rem;
    line-height: 1.4;
  }

  .tracker-entry h3 a {
    color: #1a4a8a;
  }

  .tracker-source {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .tracker-take {
    font-size: 0.95rem;
    color: #3a2010;
    line-height: 1.6;
  }
</style>
